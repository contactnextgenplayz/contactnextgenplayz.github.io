---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Hero from "@/components/Hero.astro";
import SignalStrip from "@/components/SignalStrip.astro";
import About from "@/components/About.astro";
import Services from "@/components/Services.astro";
import Hardware from "@/components/Hardware.astro";
import Footer from "@/components/Footer.astro";
import PortfolioGrid from "@/components/PortfolioGrid";
import Contact from "@/components/Contact";
---

<BaseLayout>
  <Header />
  <main id="main-content">
    <Hero />
    <SignalStrip />
    <About />

    <section id="popular" class="px-6 py-28">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="font-display text-4xl font-bold text-ink sm:text-5xl">Most Popular Videos</h2>
      </div>
      <div class="mx-auto mt-14 max-w-6xl">
        <PortfolioGrid client:visible />
      </div>
    </section>

    <Services />
    <Hardware />

    <section id="contact" class="px-6 py-28">
      <div class="mx-auto max-w-3xl text-center">
        <span class="mono-tag text-signal">Connect</span>
        <h2 class="mt-3 font-display text-4xl font-bold text-ink sm:text-5xl">Work With Me</h2>
      </div>
      <div class="mt-14">
        <Contact client:visible />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { site } from "@/lib/site";
---

<!--
  GitHub Pages automatically serves dist/404.html for any unmatched
  route on a project/user Pages site — no extra config needed, Astro
  just has to emit the file, which any src/pages/404.astro does.
-->
<BaseLayout
  title={`404 — Page Not Found | ${site.name}`}
  description="The page you're looking for doesn't exist."
  noindex
>
  <Header />
  <main
    id="main-content"
    class="viewfinder placeholder-pattern flex min-h-screen flex-col items-center justify-center px-6 py-32 text-center"
  >
    <span class="mono-tag text-signal">Signal Lost</span>
    <h1 class="mt-5 font-display text-[clamp(3.5rem,12vw,8rem)] font-bold leading-none text-ink">
      404
    </h1>
    <p class="mt-5 max-w-md text-lg text-ink-muted">
      This page went off-screen — the clip you're looking for doesn't exist, or it moved.
    </p>
    <a
      href="/"
      class="mt-9 rounded-md bg-signal px-7 py-3.5 font-display text-sm font-semibold uppercase tracking-wide text-white shadow-[0_8px_30px_-8px_rgba(255,70,85,0.5)] transition-transform hover:-translate-y-0.5"
    >
      Back to Home
    </a>
  </main>
  <Footer />
</BaseLayout>

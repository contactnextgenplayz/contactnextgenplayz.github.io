---
import { services } from "@/lib/site";
import { Gamepad2, Clapperboard, Zap } from "lucide-react";

const icons = [Gamepad2, Clapperboard, Zap];
---

<section id="services" class="px-6 py-28">
  <div class="mx-auto max-w-3xl text-center">
    <span class="mono-tag text-signal">Services</span>
    <h2 class="mt-3 font-display text-4xl font-bold text-ink sm:text-5xl">What I Offer</h2>
  </div>

  <div class="mx-auto mt-14 grid max-w-6xl grid-cols-1 gap-6 sm:grid-cols-3">
    {
      services.map((service, i) => {
        const Icon = icons[i];
        return (
          <article class="glass rounded-2xl p-8 transition-colors hover:border-line-strong">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-lg bg-signal-soft text-signal">
              <Icon size={22} />
            </div>
            <h3 class="font-display text-xl font-semibold text-ink">{service.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink-muted">{service.description}</p>
          </article>
        );
      })
    }
  </div>
</section>

---
import { hardware } from "@/lib/site";
---

<section id="hardware" class="px-6 py-24">
  <div class="mx-auto max-w-3xl text-center">
    <span class="mono-tag text-data">Platform</span>
    <h2 class="mt-3 font-display text-4xl font-bold text-ink sm:text-5xl">Platforms</h2>
  </div>

  <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 overflow-hidden rounded-2xl border border-line divide-y divide-line sm:grid-cols-3 sm:divide-y-0 sm:divide-x">
    {hardware.map((item) => (
      <div class="bg-surface p-10 text-center">
        <p class="font-display text-2xl font-semibold tracking-wide text-ink sm:text-3xl">
          {item.name}
        </p>
      </div>
    ))}
  </div>
</section>
